# APEX Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# Anthropic API (for Apex orchestrator + Critic deep review)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Ollama (default localhost, change for remote inference in Phase 3)
OLLAMA_URL=http://localhost:11434

# APEX Home (default ~/apex-studio)
APEX_HOME=/Users/abdulmanan/apex-studio
